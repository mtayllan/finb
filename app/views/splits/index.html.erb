<div class="w-full max-w-full space-y-6">
  <%# Header with month navigation %>
  <div class="flex items-center justify-between">
    <div class="flex flex-col gap-1">
      <h1 class="text-xl sm:text-3xl font-extrabold">Splits</h1>
      <p class="text-sm text-base-content/60 hidden sm:block">Track shared expenses and settle up</p>
    </div>
    <div class="flex items-center gap-1.5 sm:gap-2">
      <%= link_to url_for(month: @month.prev_month.strftime('%Y/%m')), class: "flex items-center justify-center w-[30px] h-[30px] sm:w-9 sm:h-9 rounded-lg bg-neutral" do %>
        <i class="ph-bold ph-caret-left text-lg"></i>
      <% end %>
      <span class="text-sm sm:text-base font-semibold px-1 sm:px-2">
        <span class="sm:hidden"><%= @month.strftime('%b %Y') %></span>
        <span class="hidden sm:inline"><%= @month.strftime('%B %Y') %></span>
      </span>
      <%= link_to url_for(month: @month.next_month.strftime('%Y/%m')), class: "flex items-center justify-center w-[30px] h-[30px] sm:w-9 sm:h-9 rounded-lg bg-neutral" do %>
        <i class="ph-bold ph-caret-right text-lg"></i>
      <% end %>
    </div>
  </div>

  <%# Settlement cards %>
  <% @summaries.each do |summary| %>
    <% net = summary[:other_owed] - summary[:me_owed] %>
    <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-5 rounded-2xl bg-[#142238] border border-[#15253b] p-4 sm:p-5 sm:px-6">
      <%# Top/Left: big result %>
      <div class="flex flex-col gap-0.5 sm:gap-1 flex-1">
        <span class="text-xs font-semibold text-base-content/60 tracking-wide">Me × <%= summary[:other].username %></span>
        <% if net > 0 %>
          <span class="text-2xl sm:text-3xl font-extrabold text-primary leading-tight"><%= number_to_currency(net) %></span>
          <span class="text-xs sm:text-sm text-base-content"><%= summary[:other].username %> must pay you</span>
        <% elsif net < 0 %>
          <span class="text-2xl sm:text-3xl font-extrabold text-error leading-tight"><%= number_to_currency(net.abs) %></span>
          <span class="text-xs sm:text-sm text-base-content">You must pay <%= summary[:other].username %></span>
        <% else %>
          <span class="text-2xl sm:text-3xl font-extrabold text-base-content/60 leading-tight">Settled</span>
          <span class="text-xs sm:text-sm text-base-content">No balance due</span>
        <% end %>
      </div>
      <%# Divider (mobile only) %>
      <div class="border-t border-base-content/20 sm:hidden"></div>
      <%# Bottom/Right: breakdown rows %>
      <div class="flex flex-col gap-2 sm:gap-3 sm:w-[280px] sm:shrink-0">
        <div class="flex items-center justify-between">
          <span class="text-xs text-base-content/60"><%= summary[:other].username %> owes you</span>
          <span class="text-xs sm:text-sm font-semibold text-success"><%= number_to_currency(summary[:other_owed]) %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-xs text-base-content/60">You owe <%= summary[:other].username %></span>
          <span class="text-xs sm:text-sm font-semibold text-error">- <%= number_to_currency(summary[:me_owed]) %></span>
        </div>
        <div class="border-t border-base-content/20 hidden sm:block"></div>
        <div class="hidden sm:flex items-center justify-between">
          <span class="text-xs font-semibold">Result</span>
          <span class="text-sm font-bold text-primary"><%= number_to_currency(net.abs) %></span>
        </div>
      </div>
    </div>
  <% end %>

  <%# Tabs %>
  <div data-controller="tabs">
    <div class="flex border-b border-neutral">
      <button class="flex items-center justify-center sm:justify-start gap-1.5 sm:gap-2 px-4 sm:px-5 py-2.5 sm:py-3 text-xs sm:text-sm font-semibold text-primary border-b-2 border-primary cursor-pointer flex-1 sm:flex-none"
              data-tabs-target="tab" data-action="click->tabs#switch">
        <i class="ph-bold ph-arrow-up-right"></i>
        As Payer
        <span class="badge badge-sm badge-soft badge-primary"><%= @payer_count %></span>
      </button>
      <button class="flex items-center justify-center sm:justify-start gap-1.5 sm:gap-2 px-4 sm:px-5 py-2.5 sm:py-3 text-xs sm:text-sm font-medium text-base-content/60 border-b-2 border-transparent cursor-pointer flex-1 sm:flex-none"
              data-tabs-target="tab" data-action="click->tabs#switch">
        <i class="ph-bold ph-arrow-down-left"></i>
        As Borrower
        <%= render "borrower_badge", pending_count: @pending_count, borrower_count: @borrower_count %>
      </button>
    </div>

    <%# As Payer panel %>
    <div data-tabs-target="panel" class="mt-4">
      <% if @splits_as_payer.any? %>
        <div class="flex flex-col">
          <div class="hidden lg:grid lg:grid-cols-12 gap-4 text-xs font-semibold text-base-content/50 uppercase tracking-wide px-4 pb-2">
            <div class="col-span-1">Date</div>
            <div class="col-span-4">Description</div>
            <div class="col-span-2 text-right">Total</div>
            <div class="col-span-2 text-right">Borrowed</div>
            <div class="col-span-1 text-center">Status</div>
            <div class="col-span-2 text-right">Actions</div>
          </div>
          <% @splits_as_payer.each do |split| %>
            <%# Desktop row %>
            <div class="hidden lg:block">
              <div class="card bg-base-200/50 hover:bg-base-200 transition-colors mb-2">
                <div class="card-body p-4">
                  <div class="grid lg:grid-cols-12 gap-4 items-center">
                    <div class="col-span-1 text-sm text-base-content/60">
                      <%= split.payer_transaction.date.to_fs(:day_month_year) %>
                    </div>
                    <div class="col-span-4">
                      <div class="font-medium"><%= split.payer_transaction.description %></div>
                    </div>
                    <div class="col-span-2 text-right">
                      <span class="font-medium"><%= number_to_currency(split.payer_transaction.value.abs) %></span>
                    </div>
                    <div class="col-span-2 text-right">
                      <span class="text-primary font-medium"><%= number_to_currency(split.amount_borrowed) %></span>
                    </div>
                    <div class="col-span-1 text-center">
                      <% if split.confirmed_at? %>
                        <span class="badge badge-soft badge-success badge-sm">Confirmed</span>
                      <% else %>
                        <span class="badge badge-soft badge-warning badge-sm">Pending</span>
                      <% end %>
                    </div>
                    <div class="col-span-2 flex gap-2 justify-end">
                      <%= link_to edit_split_path(split), class: "btn btn-ghost btn-sm btn-circle" do %>
                        <i class="ph-bold ph-pencil-simple"></i>
                      <% end %>
                      <%= link_to split, class: "btn btn-ghost btn-sm btn-circle text-error", data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' } do %>
                        <i class="ph-bold ph-trash"></i>
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <%# Mobile row %>
            <div class="lg:hidden flex items-center gap-3 py-3.5 border-b border-neutral">
              <div class="flex flex-col gap-0.5 flex-1 min-w-0">
                <span class="text-sm font-medium truncate"><%= split.payer_transaction.description %></span>
                <span class="text-xs text-base-content/60"><%= split.payer_transaction.date.strftime('%d/%m') %></span>
              </div>
              <div class="flex flex-col items-end gap-0.5 shrink-0">
                <span class="text-sm font-semibold"><%= number_to_currency(split.payer_transaction.value.abs) %></span>
                <span class="text-xs text-base-content/60">split <%= number_to_currency(split.amount_borrowed) %></span>
              </div>
              <% if split.confirmed_at? %>
                <span class="badge badge-soft badge-success badge-xs">Confirmed</span>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-12 text-base-content/50">
          <i class="ph-bold ph-receipt text-4xl mb-2"></i>
          <p>No splits as payer this month</p>
        </div>
      <% end %>
    </div>

    <%# As Borrower panel %>
    <div data-tabs-target="panel" class="hidden mt-4">
      <% if @splits_as_borrower.any? %>
        <div class="flex flex-col">
          <div class="hidden lg:grid lg:grid-cols-12 gap-4 text-xs font-semibold text-base-content/50 uppercase tracking-wide px-4 pb-2">
            <div class="col-span-1">Date</div>
            <div class="col-span-3">Description</div>
            <div class="col-span-2 text-right">Total</div>
            <div class="col-span-2 text-right">Borrowed</div>
            <div class="col-span-4">Category / Confirm</div>
          </div>
          <% @splits_as_borrower.each do |split| %>
            <%= render "borrower_row", split: split %>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-12 text-base-content/50">
          <i class="ph-bold ph-receipt text-4xl mb-2"></i>
          <p>No splits as borrower this month</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
